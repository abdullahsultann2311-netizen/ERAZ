        </div>
        <div class="cart-item-right">
          <div class="cart-item-price">Rs. ${(priceNum(item.price)*item.qty).toLocaleString()}</div>
          <button class="cart-item-remove" onclick="removeFromCart(${i})">Remove</button>
        </div>
      </div>`).join('');

    // Build WhatsApp message
    const waMsg = encodeURIComponent(
      'Hello ERAZ, I would like to place an order:\n' +
      cart.map(i => `- ${i.name} x${i.qty} (${i.price})`).join('\n') +
      `\nTotal: Rs. ${total.toLocaleString()}`
    );

    el.innerHTML = `
      <div class="cart-layout">
        <div class="cart-items-section">
          <h2>Your Pieces (${cart.reduce((s,i)=>s+i.qty,0)})</h2>
          ${itemsHTML}
        </div>
        <div class="cart-summary">
          <h3>Order Summary</h3>
          <div class="summary-row"><span>Subtotal</span><span>Rs. ${subtotal.toLocaleString()}</span></div>
          <div class="summary-row"><span>Shipping</span><span>Rs. ${shipping}</span></div>
          <div class="summary-row total"><span>Total</span><span>Rs. ${total.toLocaleString()}</span></div>
          <a href="https://whatsform.com/6hrFtb" target="_blank">
            <button class="checkout-btn">Place Order</button>
          </a>
