            document.getElementById('orderForm').reset();
            document.getElementById('successState').style.display = 'none';
            document.querySelectorAll('.sz-lbl').forEach(l => {
              l.style.background = '#15100c';
              l.style.color = '#8C7B65';
            });
        }, 300);
    }

    window.submitForm = function(event) {
        event.preventDefault();
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerText = "Processing Order...";

        const selectedSize = document.querySelector('input[name="size"]:checked')?.value;
        const orderPayload = {
            product: document.getElementById('sumTitle').innerText,
            price: document.getElementById('sumPrice').innerText,
            size: selectedSize,
            customerName: document.getElementById('custName').value,
            customerPhone: "+92" + document.getElementById('custPhone').value,
            customerAddress: document.getElementById('custAddress').value,
            orderDate: new Date().toISOString(),
            status: "Pending"
            };

            const dbRef = ref(database, 'orders');
            const newOrderRef = push(dbRef);

            set(newOrderRef, orderPayload)
                .then(() => {
                    document.getElementById('successState').style.display = 'flex';
                })
                .catch((err) => {
                    console.error(err);
                    alert("Database connecting issue. Try again.");
                })
                .finally(() => {
                    btn.disabled = false;
                    btn.innerText = "Confirm Order (Cash on Delivery)";
                });
        }

        // Auto attach to any checkout buttons inside the premium look of original code
        document.querySelectorAll('.checkout-btn, .buy-btn').forEach(button => {
            button.removeAttribute('onclick');
            button.addEventListener('click', function(e) {
                e.preventDefault();
                // Get sibling product details dynamically if possible, or fall back to default
                const parent = this.closest('.product-card, .product-details, .item');
                let t = "ERAZ Premium Tee";
                let p = "PKR 3,450";
                if(parent) {
                    t = parent.querySelector('h3, h2, h1')?.innerText || t;
                    p = parent.querySelector('.price')?.innerText || p;
                }
                window.openForm(t, p);
            });
        });
  </script>

</body>
</html>
